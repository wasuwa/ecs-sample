{
  "family": "web-api-stg",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "runtimePlatform": {
    "cpuArchitecture": "AMD64",
    "operatingSystemFamily": "LINUX"
  },
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "{{ tfstate `module.service.execution_role_arn` }}",
  "taskRoleArn": "{{ tfstate `module.service.task_role_arn` }}",
  "containerDefinitions": [
    {
      "name": "backend",
      "essential": true,
      "image": "{{ tfstate `module.ecr.repository_url` }}:{{ must_env `IMAGE_TAG` }}",
      "readonlyRootFilesystem": true,
      "environment": [
        {
          "name": "PORT",
          "value": "8080"
        }
      ],
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "{{ tfstate `module.service.log_group_name` }}",
          "awslogs-region": "ap-northeast-1",
          "awslogs-stream-prefix": "backend"
        }
      }
    }
  ]
}
