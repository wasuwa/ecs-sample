{
  "serviceName": "web-api-stg-service",
  "launchType": "FARGATE",
  "desiredCount": 1,
  "networkConfiguration": {
    "awsvpcConfiguration": {
      "subnets": [
        "{{ tfstate `module.vpc.subnet_ids_by_key.app[0]` }}",
        "{{ tfstate `module.vpc.subnet_ids_by_key.app[1]` }}"
      ],
      "securityGroups": [
        "{{ tfstate `module.service.security_group_id` }}"
      ],
      "assignPublicIp": "DISABLED"
    }
  },
  "loadBalancers": [
    {
      "targetGroupArn": "{{ tfstate `module.alb.target_group_arn` }}",
      "containerName": "backend",
      "containerPort": 8080
    }
  ]
}
